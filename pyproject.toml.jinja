[project]
name = "{{ project_name }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">=3.12"
authors = [
    { name = "{{ project_author }}", email = "{{ project_author_email }}" }
]
dependencies = [
    "pytest",
]

[tool.setuptools]
package-dir = {"" = "src"}

[tool.ruff]
src = ["src"]
line-length = 100
select = ["E", "F", "B", "I"]
ignore = ["E501"]

[tool.pytest.ini_options]
testpaths = ["__test__"]
addopts = "-ra -q"